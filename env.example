# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# JWT signing secret -- REQUIRED. Generate a unique value, e.g. `openssl rand -hex 32`.
# The app refuses to start if this is unset or left at a known placeholder.
JWT_SECRET=

# Optional: timezone for scheduled jobs (defaults to UTC)
# TZ=Australia/Sydney

# Optional: override the listen port (defaults to 3000)
# PORT=3000

# Optional: override the SQLite database path (defaults to /app/data/bemby.db)
# DB_PATH=/app/data/bemby.db

# Optional: number of reverse proxy hops in front of this app (defaults to 0)
# Set to 1 if behind nginx/Caddy/Traefik, 2 if behind Cloudflare + nginx, etc.
# Required for rate limiting to work correctly when behind a proxy.
# TRUST_PROXY=1
